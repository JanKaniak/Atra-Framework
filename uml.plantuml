@startuml ImplementedNumberAttributes
allowmixing
package ImplementedNumberAttributes {
    class Attribute
    class IntegerNumberBaseAttributeClass
    class DecimalNumberBaseAttributeClass

    class AttributeInt
    class AttributeUnsignedInt
    class AttributeLong
    class AttributeCharNumber

    class AttributeDouble
    class AttributeFloat

    package ImplementedNumberAttributeDescriptions
}

IntegerNumberBaseAttributeClass -up-|> Attribute
DecimalNumberBaseAttributeClass --|> Attribute
IntegerNumberBaseAttributeClass -up-> ImplementedNumberAttributeDescriptions
DecimalNumberBaseAttributeClass --> ImplementedNumberAttributeDescriptions


AttributeInt -up-|> IntegerNumberBaseAttributeClass
AttributeUnsignedInt -up-|> IntegerNumberBaseAttributeClass
AttributeLong -up-|> IntegerNumberBaseAttributeClass
AttributeCharNumber -right-|> IntegerNumberBaseAttributeClass

AttributeDouble --|> DecimalNumberBaseAttributeClass
