@startuml MainUML
allowmixing

class Formular
package AttributeDescriptions
package Attributes
package ControlComponents

Formular --> ControlComponents
Formular --> Attributes
Formular --> AttributeDescriptions

@endumlW

@startuml AttributeDescriptions
allowmixing

package AttributeDescriptions {
    class TemplateAttributesDescription
    class TemplateAttributesDescriptionContainer
    class AttributesDescriptionsContainer
    class AttributeDescription
    class DescriptionFactory
    class GlobalLastIdOfObject
    enum AttributeType
    enum Category
    package ImplementedAttributeDescriptions
    class "{TYP}NumberBaseClass" as GenericNumberBaseClass
    note  "Tento genericky model zastupuje nasledujuce typy {TYP} : Integer, Decimal" as N1

}

TemplateAttributesDescriptionContainer -right-> TemplateAttributesDescription
TemplateAttributesDescription --> AttributesDescriptionsContainer
AttributesDescriptionsContainer ---> AttributeDescription
AttributesDescriptionsContainer -left-> DescriptionFactory
AttributesDescriptionsContainer -right-> GlobalLastIdOfObject
AttributeDescription -down-> AttributeType
AttributeDescription --> Category
GenericNumberBaseClass -up-|> AttributeDescription
ImplementedAttributeDescriptions --|> GenericNumberBaseClass
DescriptionFactory --> ImplementedAttributeDescriptions
N1 -up- GenericNumberBaseClass



@enduml


@startuml ImplementedAttributeDescriptions
package ImplementedAttributeDescriptions {
    class AttributeDescription
    class IntegerNumberBaseClass<TypeT, AttributeTypeEnumT, ImGuiDataTypeT, TypeEnumT>
    class DecimalNumberBaseClass<TypeT, AttributeTypeEnumT, ImGuiDataTypeT, TypeEnumT>

    class AttributeDescriptionInt
    class AttributeDescriptionUnsignedInt
    class AttributeDescriptionLong
    class AttributeDescriptionCharNumber

    class AttributeDescriptionDouble
    class AttributeDescriptionFloat

    class AttributeDescriptionString
    class AttributeDescriptionCharText

    class AttributeDescriptionBool

    class AttributeDescriptionCluster

}

AttributeDescription ---[hidden]- DecimalNumberBaseClass
DecimalNumberBaseClass ---[hidden]- IntegerNumberBaseClass

AttributeDescriptionInt -right-|> IntegerNumberBaseClass
AttributeDescriptionUnsignedInt -left-|> IntegerNumberBaseClass
AttributeDescriptionLong -up-|> IntegerNumberBaseClass
AttributeDescriptionCharNumber --|> IntegerNumberBaseClass


AttributeDescriptionDouble -right-|> DecimalNumberBaseClass
AttributeDescriptionFloat -left-|> DecimalNumberBaseClass

AttributeDescriptionString --|> AttributeDescription
AttributeDescriptionCharText --|> AttributeDescription

AttributeDescriptionBool -right-|> AttributeDescription

AttributeDescriptionCluster -left-|> AttributeDescription


@enduml

@startuml ImplementedNumberAttributeDescriptions
package ImplementedNumberAttributeDescriptions {
    class AttributeDescription
    class IntegerNumberBaseClass<TypeT, AttributeTypeEnumT, ImGuiDataTypeT, TypeEnumT>
    class DecimalNumberBaseClass<TypeT, AttributeTypeEnumT, ImGuiDataTypeT, TypeEnumT>

    class AttributeDescriptionInt
    class AttributeDescriptionUnsignedInt
    class AttributeDescriptionLong
    class AttributeDescriptionCharNumber

    class AttributeDescriptionDouble
    class AttributeDescriptionFloat
}

IntegerNumberBaseClass -down-|> AttributeDescription
DecimalNumberBaseClass -up-|> AttributeDescription

AttributeDescriptionInt -right-|> IntegerNumberBaseClass
AttributeDescriptionUnsignedInt -left-|> IntegerNumberBaseClass
AttributeDescriptionLong -up-|> IntegerNumberBaseClass
AttributeDescriptionCharNumber --|> IntegerNumberBaseClass


AttributeDescriptionDouble -right-|> DecimalNumberBaseClass
AttributeDescriptionFloat -left-|> DecimalNumberBaseClass
@enduml

@startuml Attributes
allowmixing

package Attributes {
    class AttributesContainer
    class AttributeFactory
    class Attribute
    class AttributesDescriptionsContainer
    package ImplementedAttributeDescriptions
    package ImplementedAttributes
    class ControlComponentsFactoriesContainer
    class ControlComponentsContainer
}
AttributesContainer -left-> AttributeFactory
AttributesContainer --> Attribute
AttributesContainer -up-> AttributesDescriptionsContainer
Attribute --> ImplementedAttributeDescriptions
AttributeFactory --> ImplementedAttributes
ImplementedAttributes -up-|> Attribute
ImplementedAttributes ..> ControlComponentsFactoriesContainer
ImplementedAttributes ..> ControlComponentsContainer
@enduml

@startuml ImplementedLogicAttributeDescription
package ImplementedLogicAttributeDescription {
    class AttributeDescription
    class AttributeDescriptionBool

}
AttributeDescriptionBool -right-|> AttributeDescription
@enduml

