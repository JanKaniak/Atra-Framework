@startuml ControlComponents
allowmixing

package ControlComponents {
    class Formular
    class ControlComponentsContainer
    class ControlComponent
    class ControlComponentsFactoriesContainer
    
    
    
    
    
    package NumberControlComponents
    package TextImplementedControlComponents
    package LogicImplementedControlComponents
    package TreeImplementedControlComponents

}

ControlComponentsContainer -left-> ControlComponent
Formular -left-> ControlComponentsFactoriesContainer
Formular ---> ControlComponentsContainer
TextImplementedControlComponents --|> ControlComponent
NumberControlComponents -up-|> ControlComponent
LogicImplementedControlComponents --|> ControlComponent
TreeImplementedControlComponents -up-|> ControlComponent

@enduml

@startuml UmlForNumberBaseControlComponent
allowmixing
package BaseClassesForNumberControlTypes {
    class ControlComponent

    class NumberBaseControlComponent<EditTypeNumber TYPE, TypeT, AttributeT> {
        {static} + <<constexpr>> type_ : EditTypeNumber = TYPE
    }
    enum EditTypeNumber
    class ControlComponentInt<TYPE>
    class ControlComponentDouble<TYPE>
    class ControlComponentFloat<TYPE>
    class ControlComponentCharNumber<TYPE>
    class ControlComponentUInt<TYPE>
    class ControlComponentLong<TYPE>
}

NumberBaseControlComponent -right-|> ControlComponent
NumberBaseControlComponent -left-> EditTypeNumber
ControlComponentInt -up-|> NumberBaseControlComponent
ControlComponentDouble --|> NumberBaseControlComponent
ControlComponentFloat --|> NumberBaseControlComponent
ControlComponentCharNumber -up-|> NumberBaseControlComponent
ControlComponentUInt -up-|> NumberBaseControlComponent
ControlComponentLong --|> NumberBaseControlComponent

@enduml

@startuml ImplementedNumberControlComponents
allowmixing
package ImplementedNumberControlComponents {
    class "{TYP}Slider" as GenericSlider
    class "{TYP}VSlider" as GenericVSlider
    class "{TYP}Drag" as GenericDrag
    class "ControlComponent{TYP}" as GenericControlComponent
    class "{TYP}EditFactory" as GenericEditFactory

    note "Tento genericky model zastupuje \nnasledujuce typy {TYP}: \n*Int \n*Long \n*UInt \n*Double \n*Float" as N1

    class Factory
    class ControlComponentsFactoriesContainer

}


GenericSlider --|> GenericControlComponent
GenericVSlider --|> GenericControlComponent
GenericDrag --|> GenericControlComponent
GenericEditFactory --> GenericSlider
GenericEditFactory --> GenericVSlider
GenericEditFactory --> GenericDrag
GenericEditFactory -up-|> Factory
ControlComponentsFactoriesContainer -down-> Factory


@enduml

@startuml TextImplementedControlComponents
allowmixing
package TextImplementedControlComponents {
    class ControlComponentString<EditTypeString TYPE> {
        + {static} <<constexpr>>  type_ : EditTypeString = TYPE; 
    }
    class StringTextField
    class StringEditFactory {
        - registerPrototype<EditTypeStringT>() : void
    }
    enum EditTypeString

    class ControlComponentCharText {
        + {static} <<constexpr>>  type_ : EditTypeString = TYPE;
    }
    class CharTextField
    class CharTextEditFactory {
        - registerPrototype<EditTypeCharT>() : void
    }

    class Factory {
        + {abstract} createEdit(std::string type) : std::unique_ptr<ControlComponent>
        + {abstract} createDefaultEdit() : std::unique_ptr<ControlComponent>
    }
    class ControlComponentsFactoriesContainer {
        registerFactory(Factory *factory) : void
    }
    enum EditTypeCharText
}

StringTextField --|> ControlComponentString
CharTextField --|> ControlComponentCharText
StringEditFactory --> StringTextField
CharTextEditFactory --> CharTextField
ControlComponentString --> EditTypeString
ControlComponentCharText --> EditTypeCharText

StringEditFactory -up-|> Factory
CharTextEditFactory -up-|> Factory

ControlComponentsFactoriesContainer --> Factory
@enduml

@startuml LogicImplementedControlComponents
allowmixing
package LogicImplementedControlComponents {
    class CheckBox {
        + draw(std::vector<Message> &messageHistory) : void
    }
    class LogicButton {
        + draw(std::vector<Message> &messageHistory) : void
    }

    class LogicEditFactory {
        - registerPrototype<EditTypeLogicT>() : void
    }
    class Factory {
        + {abstract} createEdit(std::string type) : std::unique_ptr<ControlComponent>
        + {abstract} createDefaultEdit() : std::unique_ptr<ControlComponent>
    }
    class ControlComponentsFactoriesContainer {
        registerFactory(Factory *factory) : void
    }
    class ControlComponentBool<EditTypeLogic TYPE> {
        + {static} <<constexpr>>  type_ : EditTypeLogic = TYPE; 
    }
    enum EditTypeLogic
}

ControlComponentsFactoriesContainer --> Factory
LogicEditFactory -up-|> Factory
LogicEditFactory --> CheckBox
LogicEditFactory --> LogicButton
CheckBox --|> ControlComponentBool
LogicButton --|> ControlComponentBool
ControlComponentBool --> EditTypeLogic
@enduml

@startuml TreeImplementedControlComponents
allowmixing
package TreeImplementedControlComponents {
    class Tree {
        + draw(std::vector<Message> &messageHistory) : void
    }
    class ClusterEditFactory {
        - registerPrototype<EditTypeClusterT>() : void
    }
    class Factory {
        + {abstract} createEdit(std::string type) : std::unique_ptr<ControlComponent>
        + {abstract} createDefaultEdit() : std::unique_ptr<ControlComponent>
    }
    class ControlComponentsFactoriesContainer {
        registerFactory(Factory *factory) : void
    }
    class ControlComponentCluster<EditTypeCluster TYPE> {
        + {static} <<constexpr>>  type_ : EditTypeCluster = TYPE; 
    }
    enum EditTypeCluster
}

ControlComponentsFactoriesContainer --> Factory
ClusterEditFactory -up-|> Factory
ClusterEditFactory --> Tree
Tree --|> ControlComponentCluster
ControlComponentCluster --> EditTypeCluster

@enduml