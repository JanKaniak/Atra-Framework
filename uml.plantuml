IntegerNumberBaseAttributeClass -up-|> Attribute
DecimalNumberBaseAttributeClass --|> Attribute


AttributeInt -up-|> IntegerNumberBaseAttributeClass
AttributeUnsignedInt -up-|> IntegerNumberBaseAttributeClass
AttributeLong -up-|> IntegerNumberBaseAttributeClass
AttributeCharNumber -right-|> IntegerNumberBaseAttributeClass

AttributeDouble --|> DecimalNumberBaseAttributeClass
AttributeFloat --|> DecimalNumberBaseAttributeClass

AttributeString --|> Attribute
